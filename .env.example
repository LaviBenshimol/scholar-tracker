# WhatsApp Cloud API Credentials (only needed for webhook mode, not QR bridge)
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_VERIFY_TOKEN=any_secret_string_you_choose

# Sender Whitelist (comma-separated, empty = allow ALL senders)
ALLOWED_PHONE_NUMBERS=

# WhatsApp Template Details (webhook mode only)
TEMPLATE_NAME=citation_update
TEMPLATE_LANGUAGE=en

# Scholar Tracking
SCHOLAR_AUTHOR_ID=optional_your_google_scholar_profile_id
ORCID_ID=your_orcid_id_here
CHECK_INTERVAL_HOURS=24
SCRAPER_API_KEY=optional_proxy_key

# Database and Log locations
DB_PATH=data/citations.db
LOG_PATH=data/scholar_tracker.log
